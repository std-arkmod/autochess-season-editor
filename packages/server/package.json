{
  "name": "@autochess-editor/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:import": "tsx src/db/import-season.ts",
    "db:reset": "tsx src/db/reset.ts",
    "db:reset-import": "tsx src/db/reset.ts && tsx src/db/import-season.ts"
  },
  "dependencies": {
    "@autochess-editor/shared": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.9",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.7",
    "pg": "^8.20.0",
    "ws": "^8.20.0",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
